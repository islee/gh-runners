# .env.pve — pve deployment of the Linux runners (light/, supabase/, android/).
# Shared registration config for the runners on the pve host. Copy to .env.pve (gitignored).
# Per-runner labels are set per install (each installer/compose has its own default labels);
# this file holds the values common to all of them on this host.

GH_ORG=your-org

# Broker mode (recommended): point at the deployed token broker; no GitHub credential on the host.
BROKER_URL=https://your-broker-host
BROKER_SECRET=

# PAT fallback instead of the broker (fine-grained, organization_self_hosted_runners scope only):
# ACCESS_TOKEN=

# Per-type labels for reference (set via each installer's --labels / compose env):
#   light    : self-hosted,linux,x64,light
#   supabase : self-hosted,linux,x64,supabase
#   android  : self-hosted,linux,x64,mobile,android
