# Android E2E runner — environment template
#
# Copy this file to .env (which is gitignored) and fill in your values.
# chmod 600 .env before setting any credentials.
#
# .env files and *.env files are gitignored — NEVER commit real credentials.
# This file (env.example, no leading dot) CAN be committed and shared.

# ── GitHub org ────────────────────────────────────────────────────────────────

# The GitHub org slug this runner registers under (case-sensitive).
# Replace with your actual org name.
GH_ORG=your-org

# Labels that jobs must match to land on this runner.
# Must include self-hosted,mobile,android for standard workflow routing.
RUNNER_LABELS=self-hosted,mobile,android

# Display name prefix shown in org Settings > Actions > Runners.
# The container hostname is appended by entrypoint.sh for uniqueness.
RUNNER_NAME_PREFIX=android-runner

# ── Credentials (choose ONE model) ───────────────────────────────────────────
#
# Model A — RUNNER_TOKEN (static; pilots and one-off tests only)
#   A registration token from:
#     org Settings > Actions > Runners > New self-hosted runner
#     Copy the token from the `./config.sh --token <TOKEN>` line.
#   CAVEAT: expires ~1 h after minting. Because the runner re-registers after every ephemeral
#   job, a static RUNNER_TOKEN only survives the first registration — after it expires the
#   container can no longer re-register. Use it for a single manual test run; for an
#   unattended fleet use Model B (broker) or Model C (ACCESS_TOKEN).
RUNNER_TOKEN=

# Model B — BROKER_URL + BROKER_SECRET (recommended for multi-machine fleets)
#   Deploy https://github.com/islee/gh-runners/tree/main/broker and point here.
#   Entrypoint POSTs to $BROKER_URL/token with Authorization: Bearer $BROKER_SECRET;
#   the broker returns {"token","expires_at","url"} each cycle. No GitHub credential
#   ever lives in this container — only the broker secret.
BROKER_URL=
BROKER_SECRET=

# Model C — ACCESS_TOKEN (fine-grained PAT; self-contained alternative to the broker)
#   Entrypoint mints a fresh registration token via the GitHub REST API each cycle.
#   CRITICAL: use a fine-grained PAT scoped to `organization_self_hosted_runners` ONLY.
#   NEVER use an org admin PAT here. A leaked admin PAT can access all org repos and secrets.
#   Only set this if neither RUNNER_TOKEN nor BROKER_URL is set.
ACCESS_TOKEN=

# ── Android SDK build / runtime args ─────────────────────────────────────────
#
# These must match what the image was built with (passed as --build-arg at `docker compose build`).
# If you change them after a build, rebuild with `docker compose build --no-cache`.

# Android API level (e.g. 34 = Android 14).
ANDROID_API=34

# System image target. `google_apis` includes Play Store APIs (required by most apps).
# Other options: `default`, `google_apis_playstore` (adds actual Play Store app).
ANDROID_TARGET=google_apis

# CPU architecture for the system image.
# x86_64 is KVM-accelerated on standard Linux x86_64 hosts — use this for CI.
# arm64-v8a is native on M-series Macs but NOT available in Linux Docker without emulation.
ANDROID_ARCH=x86_64

# ── KVM access ────────────────────────────────────────────────────────────────
#
# GID of the host `kvm` group that owns /dev/kvm. The container user must be in this group to
# open the device, or the emulator fails with EACCES. Find it: `getent group kvm` (the number).
# Passing the numeric GID is more reliable than the name; leave blank to fall back to the
# group name `kvm` (works only if the container resolves it to the same GID).
KVM_GID=

# ── Resource caps ─────────────────────────────────────────────────────────────
#
# Applied via the Compose v2 top-level `cpus` / `mem_limit` keys (NOT deploy.resources,
# which is Swarm-only and silently ignored by `docker compose up`).
# Tune to leave headroom for the host OS and other workloads.

# CPU cores allocated to the runner container.
RUNNER_CPUS=4

# Memory allocated to the runner container.
# 6 GB is the practical floor: ~2 GB for the emulator + ~2 GB for the app under test
# + headroom for the runner agent and Maestro. 8 GB is comfortable.
RUNNER_MEM=6g
