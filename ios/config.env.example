# config.env.example — documents every field written to config.env by install.sh.
#
# config.env is GENERATED — do not create it by hand; run install.sh instead.
# This example file is provided as a reference. Keep config.env out of version control
# (add it to .gitignore) because it contains real credentials at runtime.
#
# install.sh writes config.env with mode 600 (owner-read/write only).

# ---------------------------------------------------------------------------
# GitHub organisation (or user) that owns the runner registration.
# Must match the org targeted by --org / GH_ORG at install time.
# ---------------------------------------------------------------------------
GH_ORG="your-org"

# ---------------------------------------------------------------------------
# Labels applied to this runner — comma-separated, no spaces.
# Workflows target runners with 'runs-on: [self-hosted, mobile, ios]'.
# ---------------------------------------------------------------------------
RUNNER_LABELS="self-hosted,mobile,ios,android"

# ---------------------------------------------------------------------------
# Absolute path where the actions/runner binary and runtime files live.
# Set via --runner-dir; default: ~/actions-runner-e2e
# ---------------------------------------------------------------------------
RUNNER_DIR="/Users/alice/actions-runner-e2e"

# ---------------------------------------------------------------------------
# Credential fields — exactly ONE of the three models should be populated.
#
# Model A: static registration token (one-off, expires ~1h after minting).
#   Survives only the first cycle of the re-registration loop. Use for
#   initial onboarding or testing; switch to Model B or PAT for long-term use.
#
# Model B: token-broker URL (recommended for fleets).
#   The broker mints registration tokens on demand via POST /token.
#   Requires BROKER_SECRET (the bearer credential for the broker API).
#   See: https://github.com/islee/gh-runners/tree/main/broker
#
# PAT (Model C): fine-grained PAT with organization_self_hosted_runners scope.
#   The loop calls the GitHub REST API each cycle to mint a fresh token.
#   IMPORTANT: this must NOT be the org admin PAT — use a scoped fine-grained PAT.
# ---------------------------------------------------------------------------
RUNNER_TOKEN=""
BROKER_URL=""
BROKER_SECRET=""
ACCESS_TOKEN=""

# ---------------------------------------------------------------------------
# Battery guard.
# 0 = skip job cycles when on battery (default; recommended for laptops).
# 1 = allow jobs on battery (use for Mac mini / always-plugged desktops).
# ---------------------------------------------------------------------------
ALLOW_BATTERY="0"
