# Containerized "light" runner environment.
# Copy to .env (gitignored) and fill in. Supply exactly ONE credential.

# GitHub org login this runner registers under.
GH_ORG=your-org

# Labels jobs must match (keep in sync with the workflow's runs-on:).
RUNNER_LABELS=self-hosted,linux,x64,light

# ── Credentials (choose ONE; priority RUNNER_TOKEN -> BROKER_URL -> ACCESS_TOKEN) ──
# Model A — static registration token (one-off; expires ~1h).
RUNNER_TOKEN=

# Model B — token-broker (recommended): no GitHub credential in the container.
# https://github.com/islee/gh-runners/tree/main/broker
BROKER_URL=
BROKER_SECRET=

# PAT fallback — fine-grained PAT scoped to organization_self_hosted_runners ONLY (never admin).
ACCESS_TOKEN=

# ── Resource caps ──
RUNNER_CPUS=2
RUNNER_MEM=2g
