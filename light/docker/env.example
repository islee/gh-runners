# Containerized "light" runner environment.
# Copy to .env (gitignored) and fill in. Supply exactly ONE credential.

# GitHub org login this runner registers under.
GH_ORG=your-org

# Labels jobs must match (keep in sync with the workflow's runs-on:).
RUNNER_LABELS=self-hosted,linux,x64,light

# ── Credentials (choose ONE; priority RUNNER_TOKEN -> BROKER_URL -> ACCESS_TOKEN) ──
# Model A — static registration token (one-off; expires ~1h).
RUNNER_TOKEN=

# Model B — token-broker (recommended): no GitHub credential in the container.
# https://github.com/islee/gh-runners/tree/main/broker
BROKER_URL=
BROKER_SECRET=

# PAT fallback — fine-grained PAT scoped to organization_self_hosted_runners ONLY (never admin).
ACCESS_TOKEN=

# ── Resource caps ──
RUNNER_CPUS=2
RUNNER_MEM=2g

# ── Fleet self-update (docker variant) ──
# bootstrap.sh checks for a fleet_update payload in the broker /token response on each
# container start and, if present, downloads + verifies runner-payload.sh before running it.
# Set AUTO_UPDATE=0 to opt out and always use the baked-in payload.
# The broker must supply a fleet_update object with manifest_sha256 for updates to flow;
# if absent (or models A/C used), the baked-in payload runs unchanged — always safe.
AUTO_UPDATE=1
# UPDATE_REPO=islee/gh-runners  # override if you fork the repo
