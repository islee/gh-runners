# Containerized "supabase" runner environment.
# Copy to .env (gitignored) and fill in. Supply exactly ONE credential.

GH_ORG=your-org
RUNNER_LABELS=self-hosted,linux,x64,supabase

# ── Credentials (choose ONE; priority RUNNER_TOKEN -> BROKER_URL -> ACCESS_TOKEN) ──
RUNNER_TOKEN=
# Token-broker (recommended): https://github.com/islee/gh-runners/tree/main/broker
BROKER_URL=
BROKER_SECRET=
# Fine-grained PAT, organization_self_hosted_runners scope ONLY (never admin).
ACCESS_TOKEN=

# ── Docker-out-of-docker wiring ──
# Identical path is bind-mounted host<->container; jobs run their Supabase stack here.
RUNNER_WORKDIR=/opt/runner-work/supabase
# GID of the host docker group (so the container user can use the mounted socket).
# Find it: getent group docker | cut -d: -f3
DOCKER_GID=

# ── Resource cap ──
RUNNER_MEM=6g

# ── Fleet self-update (docker variant) ──
# bootstrap.sh checks for a fleet_update payload in the broker /token response on each
# container start and, if present, downloads + verifies runner-payload.sh before running it
# (broker manifest key: supabase-docker). Set AUTO_UPDATE=0 to opt out and always use the
# baked-in payload. The broker must supply a fleet_update object with manifest_sha256 for
# updates to flow; if absent (or models A/C used), the baked-in payload runs unchanged.
AUTO_UPDATE=1
# UPDATE_REPO=islee/gh-runners  # override if you fork the repo
