# Containerized "supabase" runner environment.
# Copy to .env (gitignored) and fill in. Supply exactly ONE credential.

GH_ORG=your-org
RUNNER_LABELS=self-hosted,linux,x64,supabase

# ── Credentials (choose ONE; priority RUNNER_TOKEN -> BROKER_URL -> ACCESS_TOKEN) ──
RUNNER_TOKEN=
# Token-broker (recommended): https://github.com/islee/ci-runner-token-broker
BROKER_URL=
BROKER_SECRET=
# Fine-grained PAT, organization_self_hosted_runners scope ONLY (never admin).
ACCESS_TOKEN=

# ── Docker-out-of-docker wiring ──
# Identical path is bind-mounted host<->container; jobs run their Supabase stack here.
RUNNER_WORKDIR=/opt/runner-work/supabase
# GID of the host docker group (so the container user can use the mounted socket).
# Find it: getent group docker | cut -d: -f3
DOCKER_GID=

# ── Resource cap ──
RUNNER_MEM=6g
