# config.env — reference template for a "supabase" runner instance.
#
# install.sh GENERATES this file (mode 600) inside each instance dir from its flags; you normally
# don't write it by hand. It's documented here so you know every field. NEVER commit a real
# config.env — .env/*.env/config.env are gitignored.
#
# Supply exactly ONE credential (priority: RUNNER_TOKEN -> BROKER_URL -> ACCESS_TOKEN).

# GitHub org the runner registers under. Replace with your org login.
GH_ORG="your-org"

# Labels jobs must match to land here. Keep "self-hosted,linux,x64,supabase" unless your workflows
# route differently.
RUNNER_LABELS="self-hosted,linux,x64,supabase"

# Model A — static registration token (one-off; expires ~1h, survives only the first registration).
RUNNER_TOKEN=""

# Model B — token-broker (recommended): no GitHub credential on this host. The runner POSTs to
# $BROKER_URL/token with Authorization: Bearer $BROKER_SECRET each cycle.
# See https://github.com/islee/gh-runners/tree/main/broker
BROKER_URL=""
BROKER_SECRET=""

# PAT fallback — a fine-grained PAT scoped to organization_self_hosted_runners ONLY (never an admin
# PAT). The runner mints fresh registration tokens from it via the GitHub REST API each cycle.
ACCESS_TOKEN=""

# ── Fleet self-update knobs ────────────────────────────────────────────────────
# These are written by install.sh. Override with --no-auto-update / --update-repo etc.

# Master on/off for automatic fleet-code updates between jobs.
# Set 0 to opt this runner out permanently (until re-install). Never overrides via broker.
AUTO_UPDATE="1"

# Source repository for raw.githubusercontent.com manifest/code fetches.
# Must match the repo that publishes .fleet-manifest files at release tags.
UPDATE_REPO="islee/gh-runners"

# Pinned ref to follow. Empty = broker-driven (recommended): the broker tells each runner
# which ref to be on per cycle, enabling canary rollouts. Set to a tag to pin locally.
UPDATE_REF=""

# Minimum seconds between update checks, regardless of job cycle rate. Prevents hammering
# raw.githubusercontent.com when jobs run frequently. Default 300 (5 minutes).
UPDATE_MIN_INTERVAL="300"
