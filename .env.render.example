# .env.render — Render deployment of the token broker (broker/).
# Copy to .env.render (gitignored) and set real values in the Render dashboard.
# The runners do NOT deploy here; they connect to the broker URL Render gives you.

GH_ORG=your-org
GH_APP_ID=
GH_INSTALLATION_ID=

# Provide the GitHub App private key as a Render Secret File (preferred) and point to it:
GH_APP_PRIVATE_KEY_PATH=/etc/secrets/app-private-key.pem
# ...or paste the PEM inline instead (leave the PATH unset if you do):
GH_APP_PRIVATE_KEY=

# Shared bearer secret callers (runners) present. Render can auto-generate it (render.yaml),
# or set your own; copy the same value into the runner env files below.
BROKER_SECRET=

# Optional rate limit (defaults shown).
# RATE_LIMIT_PER_MINUTE=30
# RATE_LIMIT_BURST=30
