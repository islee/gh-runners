# gh-runner-broker environment — set these in your host's secret store (NOT committed:
# .env / *.env are gitignored, so this no-leading-dot example is the shareable template).

# GitHub App identity (from the App's settings page after you create it).
GH_APP_ID=
GH_INSTALLATION_ID=
GH_ORG=your-org-login

# The App private key. Either paste the .pem contents here (multi-line allowed on Render)...
GH_APP_PRIVATE_KEY=
# ...or mount it as a Render Secret File and point to it instead (takes precedence if set):
# GH_APP_PRIVATE_KEY_PATH=/etc/secrets/app-private-key.pem

# Shared secret callers (runners) present as `Authorization: Bearer <BROKER_SECRET>`.
# Render can generate this (render.yaml generateValue). Copy the same value into each runner's
# .env as BROKER_SECRET, alongside BROKER_URL = the Render service URL.
BROKER_SECRET=

# Per-client-IP rate limit on the token endpoints (token-bucket). Caps damage from a leaked or
# brute-forced BROKER_SECRET. Optional — defaults shown. Set RATE_LIMIT_PER_MINUTE=0 to disable.
# RATE_LIMIT_PER_MINUTE=30
# RATE_LIMIT_BURST=30        # defaults to RATE_LIMIT_PER_MINUTE

# Recent-activity stats backend (GET /stats). Optional — default "auto".
# Values: auto | memory | upstash | supabase
#   auto     — prefer Upstash if configured; else Supabase if configured; else in-memory
#   memory   — always in-process ring-buffer (resets on restart)
#   upstash  — Upstash Redis REST (requires UPSTASH_REDIS_REST_URL + TOKEN)
#   supabase — Supabase PostgREST (requires SUPABASE_SECRET_KEY/SERVICE_KEY + URL/REF; run supabase_stats.sql once)
# STATS_BACKEND=auto

# In-process ring-buffer settings (used by the "memory" backend only). Optional.
# RUNNER_STATS_WINDOW_SECONDS=86400   # how far back /stats aggregates (default 24h)
# RUNNER_STATS_MAX_EVENTS=10000       # ring-buffer cap (memory backstop)

# Durable /stats activity counters via Upstash Redis REST. Optional — set BOTH to enable.
# When both are set (and STATS_BACKEND=auto or =upstash), counters survive restarts/cold starts.
# UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Durable /stats activity counters via Supabase Postgres (PostgREST). Optional.
# Run broker/supabase_stats.sql once in the Supabase SQL editor to create tables + RPC.
# SUPABASE_URL=https://<your-project>.supabase.co  # or set SUPABASE_PROJECT_REF instead
# SUPABASE_PROJECT_REF=                            # alternative to SUPABASE_URL
# SUPABASE_SECRET_KEY=    # new-style secret key (sb_secret_...); use this for new projects
# SUPABASE_SERVICE_KEY=   # legacy service_role JWT alias; still works, checked if SECRET_KEY absent
# NOTE: use only SUPABASE_SECRET_KEY or SUPABASE_SERVICE_KEY — both are server-side secrets that
# bypass RLS. Never use the publishable key (sb_publishable_...) here; it is RLS-restricted.

# Fleet self-update channel. All three are OPTIONAL — when unset, /token responses contain no
# fleet_update key and the feature is fully dormant. See docs/fleet-self-update.md for the design
# and the release.sh process that populates these values after cutting a release tag.

# Git tag the fleet should track. Set by release.sh after pushing files and before moving the tag.
# FLEET_DESIRED_REF=v2026.06.26.1

# JSON object mapping runner TYPE → hex sha256 of that type's .fleet-manifest file at FLEET_DESIRED_REF.
# Computed by release.sh. The broker passes this to runners as the out-of-repo trust anchor so they
# can verify the fetched manifest without trusting GitHub alone.
# Example (single-line JSON object; all types in one value; types not listed get no fleet_update):
# FLEET_MANIFEST_SHA256={"light":"<hex64>","supabase":"<hex64>","ios":"<hex64>"}

# Advisory minimum version floor string passed through to runners. Runners surface it to /stats.
# Does NOT force updates onto hosts with AUTO_UPDATE=0 — see Decisions in docs/fleet-self-update.md.
# FLEET_MIN_VERSION=2026.06.26.1
