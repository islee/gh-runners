# .env.supabase.example — Supabase (PostgREST) creds for the broker's durable /stats counters (template).
# Copy to .env.supabase (gitignored) and fill in, then set these on the broker's host env.
#
# One-time setup: run broker/supabase_stats.sql in the Supabase SQL editor (creates the table + RPC).

STATS_BACKEND=supabase

# Either the full URL or just the project ref (the broker derives the URL from the ref).
SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_PROJECT_REF=<project-ref>

# Use a SECRET key — server-side only, bypasses RLS for the increment RPC + reads.
#   New key system:  sb_secret_...        (Project Settings -> API Keys -> Secret keys)
#   Legacy fallback: the service_role JWT  (also accepted via SUPABASE_SERVICE_KEY)
# Do NOT use the publishable key (sb_publishable_...) — it is RLS-restricted and can't write here.
SUPABASE_SECRET_KEY=
