# .env.github.example — GitHub App + broker identity for the token broker (template; committed).
# Copy to .env.github (gitignored) and fill in. These map onto the broker's required env vars.

# Org login the runners register under.
GH_ORG=your-org

# From the GitHub App settings page (App ID) and the install URL (.../installations/<ID>).
GH_APP_ID=
GH_INSTALLATION_ID=

# Private key: prefer a mounted Secret File path over an inline PEM.
GH_APP_PRIVATE_KEY_PATH=/etc/secrets/app-private-key.pem
# GH_APP_PRIVATE_KEY=

# Shared bearer secret every runner presents to the broker. Generate: openssl rand -hex 32
BROKER_SECRET=
