# Credentials & runner state — NEVER commit.
# Rule: everything starting with `.env` is ignored EXCEPT `.env*.example` templates.
.env*
!.env*.example
# Other credential-bearing runner config (no leading dot; *.example stays committed).
*.env
config.env
*.pem
*.key
secrets/

# Host-specific / private deployment compose overlays (e.g. linple) — never in the public repo.
docker-compose.linple.yml
docker-compose.*.local.yml

# Claude Code context files — keep local, never publish (matches CLAUDE.md at any depth).
CLAUDE.md

# Private operator docs (host/CT hosting context, runbooks) — local-only, never publish.
private/

# actions/runner install + working artifacts (if someone installs in-tree)
actions-runner*/
_work/
_diag/
.runner
.credentials*
.runner-version
*.tar.gz

# OS / editor / tooling
.DS_Store
__pycache__/
*.pyc
