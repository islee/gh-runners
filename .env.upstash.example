# .env.upstash.example — Upstash Redis REST creds for the broker's durable /stats counters (template).
# Copy to .env.upstash (gitignored) and fill in, then set these on the broker's host env.
# Create a free DB at https://upstash.com -> Redis -> REST API.

STATS_BACKEND=upstash

UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=
