# .env.mac — macOS deployment of the iOS runner (ios/).
# Runs the iOS + Android-on-Mac E2E runner. Copy to .env.mac (gitignored).
# These map to ios/install.sh flags (--org / --broker-url / --broker-secret / --labels / etc.).

GH_ORG=your-org

# Broker mode (recommended).
BROKER_URL=https://your-broker-host
BROKER_SECRET=

# PAT fallback instead of the broker (fine-grained, organization_self_hosted_runners scope only):
# ACCESS_TOKEN=

RUNNER_LABELS=self-hosted,mobile,ios,android
RUNNER_DIR=~/actions-runner-e2e
# Set 1 on an always-plugged Mac (e.g. a Mac mini) to run on battery power.
ALLOW_BATTERY=0
